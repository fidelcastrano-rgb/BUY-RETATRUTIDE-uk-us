# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# DATABASE_URL: PostgreSQL connection string (Supabase) for storing order records.
DATABASE_URL="postgresql://user:password@host:port/dbname?sslmode=require"

# RESEND_API_KEY: API Key from Resend.com for automated customer & admin email notifications.
RESEND_API_KEY="re_123456789"

# RESEND_FROM_EMAIL: The email sender address (must be verified on Resend, e.g. orders@yourdomain.com or onboarding@resend.dev)
RESEND_FROM_EMAIL="orders@buyretat.com"

# ADMIN_EMAIL: Recipient email address for admin order notifications
ADMIN_EMAIL="admin@buyretat.com"

